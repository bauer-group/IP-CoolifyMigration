# =============================================================================
#  bg-coolify-migrate - configuration
# -----------------------------------------------------------------------------
#  /!\ COOLIFY_TOKEN MUST have `root` or `read:sensitive`.
#
#  Without that scope Coolify's ApiSensitiveData middleware silently OMITS
#  `value`, `real_value` and `docker_compose_raw` from its responses - HTTP 200,
#  no error, no redaction marker, the keys are simply absent. A migration driven
#  by a plain `read` token would recreate every environment variable EMPTY and
#  every service without its compose file.
#
#  `coolify-migrate doctor` probes for this and refuses to continue without it.
#
#  Copy to .env (gitignored) and fill in. Never commit a real token: it can read
#  every secret of every project in the team.
# =============================================================================

# =============================================================================
# Coolify instance
# =============================================================================
COOLIFY_URL=https://coolify.example.com
COOLIFY_TOKEN=CHANGE_ME_COOLIFY_ROOT_TOKEN

# Verify the instance's TLS certificate. Only disable for a lab with a
# self-signed cert, never against production.
COOLIFY_VERIFY_TLS=true
COOLIFY_TIMEOUT=30.0

# =============================================================================
# Transfer
# =============================================================================
# direct  = source pushes straight to target (fastest; your laptop may disconnect)
# tunnel  = relay TCP through this workstation (when source cannot reach target)
# auto    = probe for direct, fall back to tunnel
TRANSFER_MODE=auto

# Concurrent rsync streams per volume. A volume containing hardlinks is always
# transferred as ONE stream regardless: rsync -H only detects hardlinks within a
# single invocation, so splitting would explode them into duplicate files.
TRANSFER_PARALLEL=4

# rsync -z. Off by default: volume data is usually already compressed and
# server-to-server links are usually fast. Turn on for a slow WAN link.
TRANSFER_COMPRESS=false

# rsync --bwlimit in KB/s. Empty = unlimited.
# TRANSFER_BANDWIDTH_KBPS=

# Parallelism for sha256 manifest generation (the CPU-bound part of verifying).
VERIFY_PARALLEL=4

# Required free space on the target as a multiple of the ACTUAL payload.
# (Geczy's script checks a fixed 1 GB floor and never compares it against the
# size it just computed - which is how a 100 GB migration dies mid-transfer.)
DISK_HEADROOM_FACTOR=1.2

# =============================================================================
# SSH
# =============================================================================
SSH_TIMEOUT=15.0

# Our managed known_hosts. Defaults to the state dir. Host key checking is NEVER
# disabled; an unknown key is an error you must accept once.
# SSH_KNOWN_HOSTS=

# Record an unseen host key instead of refusing. A CHANGED key is still refused.
TRUST_HOST_KEY=false

# How long to wait for a stack to stop. Generous on purpose: a large database can
# take minutes to flush, and a SIGKILL at the timeout means an unflushed, torn
# volume - which this tool treats as a hard failure, not a warning.
STOP_TIMEOUT=300.0

# =============================================================================
# Observability
# =============================================================================
LOG_LEVEL=INFO
# console = Rich, for humans | json = one object per line, for CI/log shipping
LOG_FORMAT=console

# Where migration journals live. Defaults to the platform state dir.
# STATE_DIR=

NO_COLOR=false
