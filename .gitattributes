# Normalise line endings to LF in the repo (CI runs on Linux); avoids CRLF churn.
# This matters more here than in most repos: we generate shell command lines that
# run on remote Linux hosts, and a stray CR breaks them in ways that are hard to see.
* text=auto eol=lf

# Binary / generated artefacts left untouched
*.png binary
*.ico binary

# Generated files that are text but should not be normalised
*.svg text eol=lf
uv.lock text eol=lf
